' ════════════════════════════════════════════════════════════════
' PACKAGE: src.training
' ════════════════════════════════════════════════════════════════
package "src.training" #FDFEFE {

  abstract class BaseTrainer <<abstract>> {
    {abstract} + train_epoch(loader: DataLoader): dict
    {abstract} + eval_epoch(loader: DataLoader): dict
    {abstract} + save_checkpoint(epoch: int, metrics: dict)
    {abstract} + fit(train_loader, val_loader, epochs: int)
  }

  class Trainer {
    - model: nn.Module
    - optimizer: Optimizer
    - scheduler: LRScheduler | None
    - device: torch.device
    - criterion: BCEWithLogitsLoss
    - grad_clip: float | None
    - label_smoothing: float
    - mixup_alpha: float
    - precision: str  ' fp32 | tf32 | amp | bf16
    - _use_amp: bool
    - _scaler: GradScaler
    - _batch_hooks: list
    + register_batch_hook(fn)
    - _autocast(): context
    + train_epoch(loader): dict
    + eval_epoch(loader): dict
    + save_checkpoint(epoch, metrics)
    + load_checkpoint(path): dict
    + fit(train_loader, val_loader, epochs)
  }

  class DDPTrainer {
    - rank: int
    - world_size: int
    - _epoch: int
    ' precision reenviada a Trainer
    + train_epoch(loader): dict
    + eval_epoch(loader): dict
    + save_checkpoint(epoch, metrics)
  }

  class HeterogeneousDDPTrainer {
    - local_batch_size: int
    - _criterion_sum: BCEWithLogitsLoss
    + train_epoch(loader): dict
    .. normaliza grad por batch global ..
  }

  class TrainingSessionBuilder <<Builder>> {
    - _cfg: dict
    - _device: torch.device
    - _rank: int
    - _world_size: int
    - _distributed: bool
    - _model_name: str | None
    - _trace: str
    - _layers: list[str]
    - _fn: list[str]
    - _metrics: list[str]
    - _inspect: set[str] | None
    - _batch_log_every: int | None
    - _hetero_local_batch_size: int | None
    - _output_mode: str | None
    + with_model(name): Self
    + with_trace(mode): Self
    + with_layers(*layers): Self
    + with_fn(*fns): Self
    + with_metrics(*metrics): Self
    + with_inspect(*features): Self
    + with_batch_log_every(n): Self
    + with_heterogeneous_ddp(local_bs): Self
    + with_output_mode(mode): Self
    + build(): BaseTrainer
  }

  class HeterogeneousDistributedSampler {
    - dataset: Dataset
    - weights: list[int | float]
    - rank: int
    - world_size: int
    - num_samples: int
    + set_epoch(epoch)
    + __iter__(): Iterator[int]
    + __len__(): int
  }

  note as aug_note
    **augmentations.py**
    mixup_batch(images, labels, alpha)
    → tuple[Tensor, Tensor]
    Mezcla pares con coef. Beta(α,α).
  end note

  note as metrics_note
    **metrics.py**
    f1_score / precision / recall /
    accuracy / eta_str
    Funciones puras sobre tensores GPU.
  end note

  note as logger_note
    **logger_setup.py**
    setup_logger(name, level, log_file)
    Logger "trainer" compartido.
  end note

}

