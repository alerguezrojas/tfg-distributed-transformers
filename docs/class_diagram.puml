' ════════════════════════════════════════════════════════════════
' PACKAGE: src.training
' ════════════════════════════════════════════════════════════════
package "src.training" #FDFEFE {

  abstract class BaseTrainer <<abstract>> {
    {abstract} + train_epoch(loader: DataLoader): dict
    {abstract} + eval_epoch(loader: DataLoader): dict
    {abstract} + save_checkpoint(epoch: int, metrics: dict)
    {abstract} + fit(train_loader, val_loader, epochs: int)
  }

  class Trainer {
    - model: nn.Module
    - optimizer: Optimizer
    - scheduler: LRScheduler | None
    - device: torch.device
    - checkpoint_dir: Path
    - criterion: BCEWithLogitsLoss
    - grad_clip: float | None
    - label_smoothing: float
    - mixup_alpha: float
    + train_epoch(loader): dict
    + eval_epoch(loader): dict
    + save_checkpoint(epoch, metrics)
    + fit(train_loader, val_loader, epochs)
  }

  class DDPTrainer {
    - rank: int
    - world_size: int
    - _epoch: int
    + train_epoch(loader): dict
    + eval_epoch(loader): dict
    + save_checkpoint(epoch, metrics)
  }

  class TrainingSessionBuilder <<Builder>> {
    - _cfg: dict
    - _device: torch.device
    - _timestamp: str
    - _rank: int
    - _world_size: int
    - _model_name: str | None
    - _trace: str
    - _layers: list[str]
    - _fn: list[str]
    - _metrics: list[str]
    - _inspect: set[str] | None
    + with_model(name): Self
    + with_trace(mode): Self
    + with_layers(*layers): Self
    + with_fn(*fns): Self
    + with_metrics(*metrics): Self
    + with_inspect(*features): Self
    + build(): BaseTrainer
    + print_config(model_params)
  }

  note as aug_note
    **augmentations.py**
    mixup_batch(images, labels, alpha)
    → tuple[Tensor, Tensor]
    Mezcla pares del batch con coef. Beta(α,α).
    Compatible con clasificación multi-label.
  end note

  note as metrics_note
    **metrics.py**
    f1_score(preds, labels) → float
    precision(preds, labels) → float
    recall(preds, labels) → float
    accuracy(preds, labels) → float
    eta_str(elapsed, done, total) → str
    Funciones puras sobre tensores GPU.
  end note

  note as logger_note
    **logger_setup.py**
    setup_logger(name, level, log_file) → Logger
    Configura handler de consola + fichero.
    El logger "trainer" es el que usan todos
    los decoradores y fn_decorators.
  end note

}

' ════════════════════════════════════════════════════════════════
' PACKAGE: src.training.decorators
' ════════════════════════════════════════════════════════════════
package "src.training.decorators" #FDFEFE {

  ' ── Base decorator ─────────────────────────────────────────
  class TrainerDecorator {
    # _trainer: BaseTrainer
    + train_epoch(loader): dict
    + eval_epoch(loader): dict
    + save_checkpoint(epoch, metrics)
    + fit(train_loader, val_loader, epochs)
    + __getattr__(name: str)
  }

  ' ── Template Method controller ─────────────────────────────
  class EpochController {
    - _patience: int | None
    + fit(train_loader, val_loader, epochs)
    # _on_fit_start(epochs: int)
    # _on_epoch_start(epoch, epochs)
    # _on_epoch_end(epoch, epochs, train_m,\n  val_m, best_f1, epoch_times)
    # _on_fit_end(best_f1: float)
    # _on_early_stop(epoch, best_f1)
  }

  ' ── Controllers ────────────────────────────────────────────
  class TracingDecorator {
    - _logger: Logger | None
    - _epoch_csv: Path | None
    + save_checkpoint(epoch, metrics)
    # _on_fit_start(epochs)
    # _on_epoch_start(epoch, epochs)
    # _on_epoch_end(...)
    # _on_fit_end(best_f1)
    - _emit(msg: str)
  }

  class DeepTracingDecorator {
    - _layer_stats: dict[str, LayerStats]
    - _param_stats: dict[str, ParamStats]
    - _forward_hooks: list
    - _param_hooks: list
    - log_every: int
    - features: set[str]
    + train_epoch(loader): dict
    # _on_fit_start(epochs)
    # _on_epoch_start(epoch, epochs)
    # _on_epoch_end(...)
    # _on_fit_end(best_f1)
    - _register_all_hooks()
    - _remove_all_hooks()
    - _log_layer_table(epoch, batch, n)
    - _log_anomalies(epoch)
    - _propagate_train_result(result)
  }

  ' ── Aspect decorators ──────────────────────────────────────
  class PlottingDecorator {
    - _history: dict[str, list[float]]
    - _output_path: Path
    - _epoch: int
    + train_epoch(loader): dict
    + eval_epoch(loader): dict
    + _record_train_result(result: dict)
    - _save_plot()
    - _subplot(ax, epochs, key, title)
  }

  class LayerHooksDecorator {
    - _hooks: list
    - _activations: dict[str, float]
    - log_every_n_epochs: int
    - _epoch: int
    + train_epoch(loader): dict
    - _register()
    - _make_hook(name: str)
    - _remove()
    - _print()
  }

  class ConfusionMatrixDecorator {
    - _output_dir: Path
    - _timestamp: str
    - _csv_path: Path | None
    - _epoch: int
    + eval_epoch(loader): dict
    - _save_matrix(preds, labels, epoch)
    - _write_csv(preds, labels, epoch)
  }

  class BatchMonitorDecorator {
    - _log_every: int
    - _csv_path: Path
    - _epoch: int
    + train_epoch(loader): dict
  }

  ' ── Metric reporters ───────────────────────────────────────
  abstract class _MetricReporter {
    - _logger: Logger | None
    - _emit(msg: str)
  }

  abstract class _TrainValReporter {
    - _key: str
    - _label: str
    - _cached_train: float | None
    + train_epoch(loader): dict
    + eval_epoch(loader): dict
  }

  class LossReporter {
    - _key = "loss"
    - _label = "loss"
  }

  class F1Reporter {
    - _key = "f1"
    - _label = "f1"
  }

  class AccuracyReporter {
    - _key = "accuracy"
    - _label = "accuracy"
  }

  class PrecisionRecallReporter {
    + eval_epoch(loader): dict
  }

}

