' PACKAGE: src.training.decorators — dataclasses internas
' ════════════════════════════════════════════════════════════════
package "src.training.decorators (dataclasses)" #FDFEFE {

  class LayerStats <<dataclass>> {
    + act_mean: float
    + act_std: float
    + act_max: float
    + dead_ratio: float
    + grad_norm: float
    + grad_max: float
    + vanishing: bool
    + exploding: bool
  }

  class ParamStats <<dataclass>> {
    + weight_norm: float
    + grad_norm: float
    + grad_max: float
    + update_ratio: float
    + vanishing: bool
    + exploding: bool
  }

}

' ════════════════════════════════════════════════════════════════
' PACKAGE: src.training (fn_decorators)
' ════════════════════════════════════════════════════════════════
package "src.training.fn_decorators" #FDFEFE {

  class _PowerSampler {
    - _samples: list[float]
    - _stop: threading.Event
    - _thread: Thread | None
    - _handle
    - _error: str | None
    + available: bool
    + start()
    - _run()
    + stop(): tuple[float, float]
  }

  note as fn_note
    **Decoradores @ de función**
    timed(fn) → wrapper
    log_call(fn) → wrapper
    retry_on_cuda_oom(fn) → wrapper
    measure_energy(fn) → wrapper
    Ruteados a logging.getLogger("trainer")
    con fallback a print() si no hay logger.
  end note

  _PowerSampler .. fn_note

}

