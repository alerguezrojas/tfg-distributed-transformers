package "src.training.convergence_study" #FDFEFE {

  class ConvergenceStudy {
    - _device: torch.device
    - _family: str
    - _criterion: BCEWithLogitsLoss
    + lr_range_test(model, loader): LRRangeResult
    + convergence_test(model, loader, lr, n_steps): ConvergenceResult
    + gradient_noise_scale(model, loader): GradientNoiseResult
    + run_full_study(...): StudyReport
  }

  class LRRangeResult <<dataclass>> {
    + lrs: list[float]
    + losses: list[float]
    + suggested_lr: float
    + min_loss_lr: float
    + diverged_lr: float | None
  }

  class ConvergenceResult <<dataclass>> {
    + steps: list[int]
    + losses: list[float]
    + f1s: list[float]
    + fit_a / fit_b / fit_c: float
    + r_squared: float
    + extrapolated_best_f1: float
    + epochs_to_plateau: int
    + measured_imgs_per_s: float
  }

  class GradientNoiseResult <<dataclass>> {
    + grad_norm_mean: float
    + grad_norm_std: float
    + noise_scale: float
    + suggested_batch_size: int
    + cv: float
  }

  class StudyReport <<dataclass>> {
    + lr_range: LRRangeResult | None
    + convergence: ConvergenceResult | None
    + gradient_noise: GradientNoiseResult | None
    + notes: str
  }

  note as fit_note
    **funciones puras (testeables)**
    fit_power_law(steps, losses)
    → (a, b, c, r²)
    extrapolate_power_law(a,b,c,t)
    loss_to_f1_estimate(loss, family)
  end note

}

